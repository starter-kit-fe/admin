# =============================================================================
# Required
# =============================================================================

POSTGRES_PASSWORD=changeme

# =============================================================================
# Application  (optional — defaults shown)
# =============================================================================

# Docker image to run. Set this to pin a specific release.
# APP_IMAGE=ghcr.io/starter-kit-fe/admin:latest

# Port exposed on the host.
# APP_PORT=27507

# JWT / session signing secret.
# Auto-generated by `make up` on first run — override only if you need a fixed value.
# AUTH_SECRET=

# =============================================================================
# PostgreSQL  (optional — defaults shown)
# =============================================================================

# POSTGRES_DB=admin
# POSTGRES_USER=admin

# Full connection URL. Auto-derived from the values above — override for an external DB.
# DB_URL=postgres://admin:changeme@postgres:5432/admin?sslmode=disable

# =============================================================================
# Redis  (optional — defaults shown)
# =============================================================================

# Full connection URL. Auto-derived from POSTGRES_PASSWORD — override for an external Redis.
# REDIS_URL=redis://:changeme@redis:6379/0
